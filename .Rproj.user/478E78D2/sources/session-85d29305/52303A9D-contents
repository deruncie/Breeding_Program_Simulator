bp_pop_n_ind <- function(pop) {
  if (methods::is(pop, "Pop")) {
    return(as.integer(pop@nInd))
  }
  if (methods::is(pop, "RawPop")) {
    return(as.integer(pop@nInd))
  }
  out <- tryCatch(nrow(pop), error = function(e) NA_integer_)
  if (length(out) == 1L && !is.na(out)) {
    return(as.integer(out))
  }
  stop("Unable to determine number of individuals for pop", call. = FALSE)
}

bp_pop_subset <- function(pop, idx) {
  idx <- as.integer(idx)
  if (methods::is(pop, "Pop") || methods::is(pop, "RawPop")) {
    return(pop[idx])
  }
  if (is.data.frame(pop) || is.matrix(pop)) {
    return(pop[idx, , drop = FALSE])
  }
  out <- tryCatch(pop[idx], error = function(e) NULL)
  if (!is.null(out)) {
    return(out)
  }
  stop("Unable to subset pop with [idx]", call. = FALSE)
}

bp_new_cohort_id <- function(state) {
  state$counters$cohort <- state$counters$cohort + 1L
  list(
    id = sprintf("cohort_%07d", state$counters$cohort),
    state = state
  )
}

bp_years_to_ticks <- function(state, years) {
  as.integer(round(as.numeric(years) / state$time$dt))
}

bp_chip_key <- function(chip) {
  as.character(chip)
}

bp_chip_index <- function(state, chip) {
  if (is.numeric(chip)) return(as.integer(chip))
  if (is.character(chip) && !is.null(state$sim$chip_map[[chip]])) {
    return(as.integer(state$sim$chip_map[[chip]]))
  }
  if (is.character(chip) && grepl("^[0-9]+$", chip)) {
    return(as.integer(chip))
  }
  stop("chip must be numeric, numeric string, or present in state$sim$chip_map", call. = FALSE)
}

bp_add_cost <- function(state, stage, cohort_id, event, unit, n_units, unit_cost) {
  row <- data.frame(
    tick = as.integer(state$time$tick),
    stage = as.character(stage),
    cohort_id = as.character(cohort_id),
    event = as.character(event),
    unit = as.character(unit),
    n_units = as.numeric(n_units),
    unit_cost = as.numeric(unit_cost),
    total_cost = as.numeric(n_units) * as.numeric(unit_cost),
    stringsAsFactors = FALSE
  )
  state$cost_log <- rbind(state$cost_log, row)
  state
}

bp_add_cohort <- function(
  state,
  pop,
  stage,
  stream = "main",
  cycle_id = "cycle_1",
  source_cohort_id = NA_character_,
  duration_years = 0,
  active = TRUE
) {
  id_out <- bp_new_cohort_id(state)
  cohort_id <- id_out$id
  state <- id_out$state

  dur_ticks <- bp_years_to_ticks(state, duration_years)
  done_tick <- as.integer(state$time$tick + dur_ticks)

  row <- data.frame(
    cohort_id = cohort_id,
    stage = as.character(stage),
    stream = as.character(stream),
    cycle_id = as.character(cycle_id),
    source_cohort_id = as.character(source_cohort_id),
    created_tick = as.integer(state$time$tick),
    done_tick = done_tick,
    available_tick = done_tick,
    closed_tick = NA_integer_,
    active = isTRUE(active),
    n_ind = bp_pop_n_ind(pop),
    genotyped = FALSE,
    chips = "",
    stringsAsFactors = FALSE
  )

  state$cohorts <- rbind(state$cohorts, row)
  state$pops[[cohort_id]] <- pop
  list(state = state, cohort_id = cohort_id)
}

bp_close_cohort <- function(state, cohort_id) {
  idx <- match(cohort_id, state$cohorts$cohort_id)
  if (is.na(idx)) return(state)
  state$cohorts$active[idx] <- FALSE
  state$cohorts$closed_tick[idx] <- as.integer(state$time$tick)
  state
}

bp_get_ready_cohorts <- function(state, stage = NULL, stream = NULL, active_only = TRUE, as_of_tick = state$time$tick) {
  df <- state$cohorts
  if (!is.null(stage)) {
    df <- df[df$stage %in% stage, , drop = FALSE]
  }
  if (!is.null(stream)) {
    df <- df[df$stream %in% stream, , drop = FALSE]
  }
  if (isTRUE(active_only)) {
    df <- df[df$active, , drop = FALSE]
  }
  df <- df[df$available_tick <= as.integer(as_of_tick), , drop = FALSE]
  df
}

bp_advance_time <- function(state, n_ticks = 1L) {
  state$time$tick <- as.integer(state$time$tick + as.integer(n_ticks))
  state$time$t <- as.numeric(state$time$tick * state$time$dt)
  state <- bp_refresh_genotyped_flags(state)
  state
}

bp_refresh_genotyped_flags <- function(state) {
  if (nrow(state$cohorts) == 0L) return(state)
  chips_done <- state$genotype_log[state$genotype_log$available_tick <= state$time$tick, , drop = FALSE]

  state$cohorts$genotyped <- FALSE
  state$cohorts$chips <- ""

  if (nrow(chips_done) == 0L) return(state)

  by_cohort <- split(chips_done$chip, chips_done$cohort_id)
  for (cid in names(by_cohort)) {
    idx <- match(cid, state$cohorts$cohort_id)
    if (is.na(idx)) next
    uniq <- unique(as.character(by_cohort[[cid]]))
    state$cohorts$genotyped[idx] <- length(uniq) > 0L
    state$cohorts$chips[idx] <- paste(uniq, collapse = ";")
  }
  state
}

bp_record_pheno <- function(state, cohort_id, pop, stage, traits, n_loc, reps, available_tick) {
  tr <- as.integer(traits)
  ph <- pop@pheno
  if (is.null(dim(ph))) {
    ph <- matrix(ph, ncol = 1)
  }

  if (length(tr) == 1L) {
    vals <- ph[, tr]
    rows <- data.frame(
      cohort_id = cohort_id,
      stage = stage,
      individual_id = pop@id,
      trait = paste0("trait", tr),
      phenotype_value = as.numeric(vals),
      measured_tick = as.integer(state$time$tick),
      available_tick = as.integer(available_tick),
      n_loc = as.integer(n_loc),
      reps = as.integer(reps),
      stringsAsFactors = FALSE
    )
  } else {
    rows <- do.call(rbind, lapply(tr, function(tt) {
      data.frame(
        cohort_id = cohort_id,
        stage = stage,
        individual_id = pop@id,
        trait = paste0("trait", tt),
        phenotype_value = as.numeric(ph[, tt]),
        measured_tick = as.integer(state$time$tick),
        available_tick = as.integer(available_tick),
        n_loc = as.integer(n_loc),
        reps = as.integer(reps),
        stringsAsFactors = FALSE
      )
    }))
  }

  state$phenotype_log <- rbind(state$phenotype_log, rows)
  state
}

bp_merge_pops <- function(pop_list) {
  if (length(pop_list) == 1L) return(pop_list[[1L]])
  AlphaSimR::mergePops(pop_list)
}

run_make_f1 <- function(state, cfg) {
  ready <- bp_get_ready_cohorts(state, stage = cfg$input_stage, stream = cfg$stream %||% NULL)
  if (nrow(ready) == 0L) return(state)

  # use newest available parent cohort
  ready <- ready[order(ready$created_tick, decreasing = TRUE), , drop = FALSE]
  src <- ready[1, , drop = FALSE]
  parent_pop <- state$pops[[src$cohort_id]]

  n_crosses <- as.integer(cfg$n_crosses)
  n_progeny <- as.integer(cfg$n_progeny_per_cross %||% 1L)
  n_parents <- bp_pop_n_ind(parent_pop)
  cross_plan <- matrix(sample.int(n_parents, size = n_crosses * 2L, replace = TRUE), ncol = 2)

  f1 <- AlphaSimR::makeCross(parent_pop, crossPlan = cross_plan, nProgeny = n_progeny, simParam = state$sim$SP)

  out <- bp_add_cohort(
    state = state,
    pop = f1,
    stage = cfg$output_stage %||% "F1",
    stream = cfg$output_stream %||% "main",
    cycle_id = cfg$cycle_id %||% paste0("cycle_", state$time$tick),
    source_cohort_id = src$cohort_id,
    duration_years = cfg$duration_years %||% 1
  )
  state <- out$state

  state <- bp_add_cost(
    state,
    stage = cfg$output_stage %||% "F1",
    cohort_id = out$cohort_id,
    event = "crossing",
    unit = "cross",
    n_units = n_crosses,
    unit_cost = cfg$cost_per_cross %||% 1
  )
  state
}

run_ssd_to_f5 <- function(state, cfg) {
  ready <- bp_get_ready_cohorts(state, stage = cfg$input_stage, stream = cfg$stream %||% NULL)
  if (nrow(ready) == 0L) return(state)

  for (i in seq_len(nrow(ready))) {
    src <- ready[i, , drop = FALSE]
    pop <- state$pops[[src$cohort_id]]

    n_lines <- as.integer(cfg$n_lines_per_f1 %||% 5L)
    pop2 <- AlphaSimR::self(pop, nProgeny = n_lines, simParam = state$sim$SP)
    pop3 <- AlphaSimR::self(pop2, nProgeny = 1, simParam = state$sim$SP)
    pop4 <- AlphaSimR::self(pop3, nProgeny = 1, simParam = state$sim$SP)
    pop5 <- AlphaSimR::self(pop4, nProgeny = 1, simParam = state$sim$SP)

    out <- bp_add_cohort(
      state = state,
      pop = pop5,
      stage = cfg$output_stage %||% "F5",
      stream = cfg$output_stream %||% src$stream,
      cycle_id = src$cycle_id,
      source_cohort_id = src$cohort_id,
      duration_years = cfg$duration_years %||% 2
    )
    state <- out$state

    state <- bp_add_cost(
      state,
      stage = cfg$output_stage %||% "F5",
      cohort_id = out$cohort_id,
      event = "ssd",
      unit = "line",
      n_units = bp_pop_n_ind(pop5),
      unit_cost = cfg$cost_per_line %||% 0.2
    )

    if (isTRUE(cfg$consume_input %||% TRUE)) {
      state <- bp_close_cohort(state, src$cohort_id)
    }
  }

  state
}

run_phenotype_trial <- function(state, cfg) {
  ready <- bp_get_ready_cohorts(state, stage = cfg$input_stage, stream = cfg$stream %||% NULL)
  if (nrow(ready) == 0L) return(state)

  traits <- as.integer(cfg$traits %||% 1L)
  n_loc <- as.integer(cfg$n_loc %||% 1L)
  reps <- as.integer(cfg$reps %||% 1L)

  for (i in seq_len(nrow(ready))) {
    src <- ready[i, , drop = FALSE]
    pop_in <- state$pops[[src$cohort_id]]

    idx <- if (is.function(cfg$select_entries_fn)) {
      as.integer(cfg$select_entries_fn(state, src, pop_in, cfg))
    } else {
      seq_len(bp_pop_n_ind(pop_in))
    }
    if (length(idx) == 0L) next

    pop_trial <- bp_pop_subset(pop_in, idx)
    pop_trial <- AlphaSimR::setPheno(
      pop_trial,
      varE = cfg$varE,
      reps = reps,
      traits = traits,
      simParam = state$sim$SP
    )

    out <- bp_add_cohort(
      state = state,
      pop = pop_trial,
      stage = cfg$output_stage %||% cfg$trial_name,
      stream = cfg$output_stream %||% src$stream,
      cycle_id = src$cycle_id,
      source_cohort_id = src$cohort_id,
      duration_years = cfg$duration_years %||% 1
    )
    state <- out$state

    avail_tick <- state$cohorts$available_tick[match(out$cohort_id, state$cohorts$cohort_id)]
    state <- bp_record_pheno(
      state = state,
      cohort_id = out$cohort_id,
      pop = pop_trial,
      stage = cfg$output_stage %||% cfg$trial_name,
      traits = traits,
      n_loc = n_loc,
      reps = reps,
      available_tick = avail_tick
    )

    n_plots <- bp_pop_n_ind(pop_trial) * n_loc * reps
    state <- bp_add_cost(
      state,
      stage = cfg$output_stage %||% cfg$trial_name,
      cohort_id = out$cohort_id,
      event = "phenotype_trial",
      unit = "plot",
      n_units = n_plots,
      unit_cost = cfg$cost_per_plot %||% 10
    )

    if (isTRUE(cfg$consume_input %||% TRUE)) {
      state <- bp_close_cohort(state, src$cohort_id)
    }
  }

  state
}

run_genotyping <- function(state, cfg) {
  ready <- bp_get_ready_cohorts(state, stage = cfg$input_stage, stream = cfg$stream %||% NULL)
  if (nrow(ready) == 0L) return(state)

  chip <- cfg$chip %||% state$sim$default_chip
  chip_key <- bp_chip_key(chip)
  dur_ticks <- bp_years_to_ticks(state, cfg$duration_years %||% 1)

  for (i in seq_len(nrow(ready))) {
    src <- ready[i, , drop = FALSE]
    n_ind <- src$n_ind

    row <- data.frame(
      cohort_id = src$cohort_id,
      chip = chip_key,
      started_tick = as.integer(state$time$tick),
      done_tick = as.integer(state$time$tick + dur_ticks),
      available_tick = as.integer(state$time$tick + dur_ticks),
      n_ind = as.integer(n_ind),
      stringsAsFactors = FALSE
    )
    state$genotype_log <- rbind(state$genotype_log, row)

    state <- bp_add_cost(
      state,
      stage = src$stage,
      cohort_id = src$cohort_id,
      event = "genotyping",
      unit = "sample",
      n_units = n_ind,
      unit_cost = cfg$cost_per_sample %||% 15
    )
  }

  state <- bp_refresh_genotyped_flags(state)
  state
}

bp_get_training_pyt <- function(state, cfg) {
  ready <- bp_get_ready_cohorts(state, stage = cfg$from_stage, stream = cfg$stream %||% NULL)
  if (nrow(ready) == 0L) return(ready)

  lookback_ticks <- bp_years_to_ticks(state, cfg$lookback_years %||% 3)
  min_tick <- as.integer(state$time$tick - lookback_ticks)
  ready <- ready[ready$available_tick >= min_tick, , drop = FALSE]

  chip_key <- bp_chip_key(cfg$chip %||% state$sim$default_chip)
  if (nrow(ready) == 0L) return(ready)

  has_chip <- vapply(ready$cohort_id, function(cid) {
    any(state$genotype_log$cohort_id == cid & state$genotype_log$chip == chip_key & state$genotype_log$available_tick <= state$time$tick)
  }, logical(1))
  ready[has_chip, , drop = FALSE]
}

run_train_gp_model <- function(state, cfg) {
  train_cohorts <- bp_get_training_pyt(state, cfg)
  if (nrow(train_cohorts) == 0L) return(state)

  pops <- lapply(train_cohorts$cohort_id, function(cid) state$pops[[cid]])
  train_pop <- bp_merge_pops(pops)

  chip_raw <- cfg$chip %||% state$sim$default_chip
  chip_key <- bp_chip_key(chip_raw)
  chip_idx <- bp_chip_index(state, chip_raw)
  trait <- as.integer(cfg$trait %||% 1L)
  model <- AlphaSimR::RRBLUP(train_pop, traits = trait, use = "pheno", snpChip = chip_idx, simParam = state$sim$SP)

  state$counters$model <- state$counters$model + 1L
  model_id <- as.character(cfg$model_id %||% sprintf("gp_%03d", state$counters$model))

  state$gs_models[[model_id]] <- list(
    model = model,
    trained_tick = as.integer(state$time$tick),
    chip = chip_key,
    trait = trait,
    source_cohorts = train_cohorts$cohort_id
  )

  state
}

bp_latest_model_id <- function(state) {
  if (length(state$gs_models) == 0L) return(NULL)
  ord <- order(vapply(state$gs_models, function(x) x$trained_tick, numeric(1)), decreasing = TRUE)
  names(state$gs_models)[ord][1]
}

run_select_variety_and_recycle <- function(state, cfg) {
  ready <- bp_get_ready_cohorts(state, stage = cfg$input_stage, stream = cfg$stream %||% NULL)
  if (nrow(ready) == 0L) return(state)

  model_id <- as.character(cfg$model_id %||% bp_latest_model_id(state))
  if (is.null(model_id) || !nzchar(model_id) || is.null(state$gs_models[[model_id]])) {
    return(state)
  }
  model_obj <- state$gs_models[[model_id]]$model

  for (i in seq_len(nrow(ready))) {
    src <- ready[i, , drop = FALSE]
    pop <- state$pops[[src$cohort_id]]

    # Variety from observed PYT phenotype.
    variety <- AlphaSimR::selectInd(pop, nInd = as.integer(cfg$n_variety %||% 1L), use = "pheno", simParam = state$sim$SP)
    var_ids <- as.integer(variety@id)
    state$outputs$varieties <- rbind(
      state$outputs$varieties,
      data.frame(
        tick = as.integer(state$time$tick),
        source_cohort_id = src$cohort_id,
        variety_id = var_ids,
        stringsAsFactors = FALSE
      )
    )

    # Recycle best predicted lines as new parents.
    pop_ebv <- AlphaSimR::setEBV(pop, solution = model_obj, simParam = state$sim$SP)
    n_par <- as.integer(cfg$n_new_parents %||% 50L)
    n_par <- min(n_par, bp_pop_n_ind(pop_ebv))
    new_parents <- AlphaSimR::selectInd(pop_ebv, nInd = n_par, use = "ebv", simParam = state$sim$SP)

    if (isTRUE(cfg$replace_all_parents %||% TRUE)) {
      old_par <- bp_get_ready_cohorts(state, stage = cfg$parent_stage %||% "PARENT", active_only = TRUE)
      if (nrow(old_par) > 0L) {
        for (j in seq_len(nrow(old_par))) {
          state <- bp_close_cohort(state, old_par$cohort_id[j])
        }
      }
    }

    out <- bp_add_cohort(
      state = state,
      pop = new_parents,
      stage = cfg$parent_stage %||% "PARENT",
      stream = cfg$parent_stream %||% "main",
      cycle_id = src$cycle_id,
      source_cohort_id = src$cohort_id,
      duration_years = cfg$parent_duration_years %||% 1
    )
    state <- out$state

    state <- bp_add_cost(
      state,
      stage = cfg$parent_stage %||% "PARENT",
      cohort_id = out$cohort_id,
      event = "parent_recycle",
      unit = "line",
      n_units = bp_pop_n_ind(new_parents),
      unit_cost = cfg$cost_per_parent %||% 0.5
    )

    if (isTRUE(cfg$consume_input %||% TRUE)) {
      state <- bp_close_cohort(state, src$cohort_id)
    }
  }

  state
}
