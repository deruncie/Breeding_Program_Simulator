Cohort <- R6Class(
  "Cohort",
  public = list(
    cohort_id = NULL,
    pipeline_instance_id = NULL,
    stage_name = NULL,
    year_entered = NULL,
    pop = NULL,
    individual_ids = NULL,
    parent_cohort_id = NULL,

    initialize = function(
      cohort_id,
      pipeline_instance_id,
      stage_name,
      year_entered,
      pop,
      individual_ids,
      parent_cohort_id = NULL
    ) {
      self$cohort_id <- as.character(cohort_id)
      self$pipeline_instance_id <- as.character(pipeline_instance_id)
      self$stage_name <- as.character(stage_name)
      self$year_entered <- as.integer(year_entered)
      self$pop <- pop
      self$individual_ids <- as.character(individual_ids)
      self$parent_cohort_id <- if (is.null(parent_cohort_id)) NULL else as.character(parent_cohort_id)

      if (length(self$individual_ids) == 0L) {
        stop("Cohort must contain at least one individual_id", call. = FALSE)
      }
    },

    size = function() {
      length(self$individual_ids)
    }
  )
)
