PipelineInstance <- R6Class(
  "PipelineInstance",
  public = list(
    instance_id = NULL,
    template_id = NULL,
    start_year = NULL,
    current_stage_index = NULL,
    current_cohort_id = NULL,
    active = NULL,

    initialize = function(
      instance_id,
      template_id,
      start_year,
      current_stage_index = 1L,
      current_cohort_id,
      active = TRUE
    ) {
      self$instance_id <- as.character(instance_id)
      self$template_id <- as.character(template_id)
      self$start_year <- as.integer(start_year)
      self$current_stage_index <- as.integer(current_stage_index)
      self$current_cohort_id <- as.character(current_cohort_id)
      self$active <- isTRUE(active)
    }
  )
)
