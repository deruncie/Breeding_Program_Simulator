founder_haps <- quickHaplo(nInd = 60, nChr = 5, segSites = 200)
sim_param <- SimParam$new(founder_haps)
sim_param$addTraitA(nQtlPerChr = 50)
sim_param$setVarE(h2 = 0.3)
founders <- newPop(founder_haps, simParam = sim_param)
SP <- sim_param

state <- ProgramState$new(year = 0)
template <- template_from_yaml("inst/config/inbred_pyt_ayt_eyt.yml")
state$add_pipeline_template(template)
state$create_initial_instance(template_id = template$template_id, pop = founders, start_year = 1)

crossing_schedule_fn <- function(state, year) {
  if (year %% 2 != 0) return(invisible(NULL))

  eligible <- state$eligible_parent_cohorts(parent_eligible_stages = c("INBRED", "PYT", "AYT", "EYT"))
  if (length(eligible) < 1) return(invisible(NULL))

  selector_fn <- function(parent_cohorts, state) {
    selected_pops <- lapply(parent_cohorts, function(ch) {
      pop_subset(ch$pop, seq_len(min(5, ch$size())))
    })
    pooled_pop <- if (length(selected_pops) == 1L) {
      selected_pops[[1L]]
    } else {
      mergePops(selected_pops)
    }
    pooled_ids <- unlist(lapply(parent_cohorts, function(ch) ch$individual_ids[seq_len(min(5, ch$size()))]))
    list(pop = pooled_pop, parent_ids = pooled_ids)
  }

  crossing_fn <- function(parent_pop, state) {
    list(pop = randCross(parent_pop, nCrosses = 20, nProgeny = 4, simParam = sim_param))
  }

  state$create_crossing_instance(
    template_id = template$template_id,
    parent_eligible_stages = c("INBRED", "PYT", "AYT", "EYT"),
    selector_fn = selector_fn,
    crossing_fn = crossing_fn,
    start_year = year,
    generation = year
  )
}

gs_update_fn <- function(state, year) {
  state$GS_models[[as.character(year)]] <- list(
    trained_on_rows = nrow(state$phenotype_log),
    updated_at_year = year
  )
}

cost_update_fn <- function(state, year) {
  state$cost_log <- rbind(
    state$cost_log,
    data.frame(year = year, event = "annual_ops", cohort_id = NA_character_, amount = 10000, stringsAsFactors = FALSE)
  )
}

simulate_years(
  state = state,
  n_years = 8,
  start_year = 1,
  crossing_schedule_fn = crossing_schedule_fn,
  gs_update_fn = gs_update_fn,
  cost_update_fn = cost_update_fn
)

